{
  "env": { "node": true, "es2022": true },
  "parserOptions": { "ecmaVersion": 2022, "sourceType": "commonjs" },
  "plugins": ["security"],
  "extends": ["eslint:recommended", "plugin:security/recommended-legacy"],
  "rules": {
    "no-console": "warn",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }]
  }
}
